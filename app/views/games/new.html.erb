
<div class="container p-3">
  <h1>New Game</h1>
  <div class="row col-6">
    <div class="d-flex justify-content-between">
      <% @letters.each do |letter| %>
        <div class="letter-box"><%= letter %></div>
      <% end %>
    </div>
  </div>
  <div class="row col-6 mt-4">
    <form action="score" method="post" data-turbo="false">
      <%= hidden_field_tag :letters, @letters %>
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <label for="word" class="form-label">What is the longest word you can find?</label>
    <!-- ... -->
      <div class="input-group col-3">
        <input id="word" name="word" type="text" class="form-control">
        <input class="input-group-text" type="submit" id="play-button" value="play">
      </div>
    </form>
  </div>
</div>
